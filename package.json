{
	"name": "mustachebash-admin",
	"version": "1.0.0",
	"description": "Mustache Bash Admin",
	"type": "module",
	"private": true,
	"author": "Wild Feather LLC",
	"scripts": {
		"start": "vite",
		"build": "tsc --noEmit && vite build",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
		"test": "eslint . && tsc --noEmit && prettier --check \"src/**/*.{ts,tsx,css}\""
	},
	"browserslist": [
		"last 1 version",
		"iOS > 11"
	],
	"dependencies": {
		"chart.js": "^4.5.1",
		"classnames": "^2.5.1",
		"date-fns": "^3.3.1",
		"html5-qrcode": "^2.3.8",
		"jwt-decode": "^4.0.0",
		"lodash": "^4.17.21",
		"normalize.css": "^8.0.1",
		"react": "^18.3.1",
		"react-chartjs-2": "^5.2.0",
		"react-dom": "^18.3.1",
		"react-router-dom": "^6.22.3"
	},
	"devDependencies": {
		"@eslint/js": "^9.17.0",
		"@react-oauth/google": "^0.12.1",
		"@types/lodash": "^4.17.12",
		"@types/node": "^20.17.10",
		"@types/react": "^18.3.18",
		"@types/react-dom": "^18.3.5",
		"@vitejs/plugin-react": "^4.3.4",
		"eslint": "^9.17.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react": "^7.37.3",
		"eslint-plugin-react-hooks": "^5.1.0",
		"eslint-plugin-react-refresh": "^0.4.16",
		"prettier": "^3.4.2",
		"typescript": "^5.7.3",
		"typescript-eslint": "^8.19.1",
		"vite": "^5.4.11"
	}
}
